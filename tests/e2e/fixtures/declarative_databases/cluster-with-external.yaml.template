apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: cluster-with-external-server
spec:
  instances: 3

  postgresql:
    parameters:
      max_connections: "110"
      log_checkpoints: "on"
      log_lock_waits: "on"
      log_min_duration_statement: '1000'
      log_statement: 'ddl'
      log_temp_files: '1024'
      log_autovacuum_min_duration: '1s'
      log_replication_commands: 'on'

  # Example of rolling update strategy:
  # - unsupervised: automated update of the primary once all
  #                 replicas have been upgraded (default)
  # - supervised: requires manual supervision to perform
  #               the switchover of the primary
  primaryUpdateStrategy: unsupervised
  primaryUpdateMethod: switchover

  bootstrap:
    initdb:
      database: srcdb
      owner: srcdb

  # Persistent storage configuration
  storage:
    storageClass: ${E2E_DEFAULT_STORAGE_CLASS}
    size: 1Gi
  walStorage:
    storageClass: ${E2E_DEFAULT_STORAGE_CLASS}
    size: 1Gi

  externalClusters:
  - name: cluster-with-declarative-databases
    connectionParameters:
      host: cluster-with-declarative-databases-rw.default.svc
      user: app
      dbname: app
      sslmode: verify-full
    sslKey:
      name: cluster-with-declarative-databases-replication
      key: tls.key
    sslCert:
      name: cluster-with-declarative-databases-replication
      key: tls.crt
    sslRootCert:
      name: cluster-with-declarative-databases-ca
      key: ca.crt
